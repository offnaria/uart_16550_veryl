// BaudGen tests — converted to embedded SystemVerilog testbenches.
// Clock period = 10 ns; reset held for 5 cycles.
// After reset, r_counter=0; with div=N, o_en fires every N cycles.

#[test(test_baud_gen_period_4)]
embed (inline) sv{{{
    module test_baud_gen_period_4;
        logic        clk;
        logic        rst_n;
        logic [15:0] i_div;
        logic        o_en;

        uart_16550_veryl_BaudGen u_dut (
            .i_clk  (clk  ),
            .i_rst_n(rst_n),
            .i_div  (i_div),
            .o_en   (o_en )
        );

        initial clk = 0;
        always #5 clk = ~clk;

        int   cur_cycle, last_cycle, pulse_count;
        logic first_seen;

        initial begin
            rst_n       = 0;
            i_div       = 4;
            cur_cycle   = 0;
            last_cycle  = 0;
            pulse_count = 0;
            first_seen  = 0;

            repeat (5) @(posedge clk);
            rst_n = 1;

            for (int i = 0; i < 40; i++) begin
                @(posedge clk);
                cur_cycle++;
                if (o_en) begin
                    if (first_seen && (cur_cycle - last_cycle !== 4))
                        $fatal(1, "Period mismatch at pulse %0d: got %0d, expected 4",
                               pulse_count, cur_cycle - last_cycle);
                    last_cycle  = cur_cycle;
                    first_seen  = 1;
                    pulse_count++;
                end
            end

            if (pulse_count !== 10)
                $fatal(1, "Expected 10 pulses in 40 cycles, got %0d", pulse_count);
            $finish();
        end
    endmodule
}}}

#[test(test_baud_gen_period_8)]
embed (inline) sv{{{
    module test_baud_gen_period_8;
        logic        clk;
        logic        rst_n;
        logic [15:0] i_div;
        logic        o_en;

        uart_16550_veryl_BaudGen u_dut (
            .i_clk  (clk  ),
            .i_rst_n(rst_n),
            .i_div  (i_div),
            .o_en   (o_en )
        );

        initial clk = 0;
        always #5 clk = ~clk;

        int   cur_cycle, last_cycle, pulse_count;
        logic first_seen;

        initial begin
            rst_n       = 0;
            i_div       = 8;
            cur_cycle   = 0;
            last_cycle  = 0;
            pulse_count = 0;
            first_seen  = 0;

            repeat (5) @(posedge clk);
            rst_n = 1;

            for (int i = 0; i < 80; i++) begin
                @(posedge clk);
                cur_cycle++;
                if (o_en) begin
                    if (first_seen && (cur_cycle - last_cycle !== 8))
                        $fatal(1, "Period mismatch at pulse %0d: got %0d, expected 8",
                               pulse_count, cur_cycle - last_cycle);
                    last_cycle  = cur_cycle;
                    first_seen  = 1;
                    pulse_count++;
                end
            end

            if (pulse_count !== 10)
                $fatal(1, "Expected 10 pulses in 80 cycles, got %0d", pulse_count);
            $finish();
        end
    endmodule
}}}

#[test(test_baud_gen_disabled)]
embed (inline) sv{{{
    module test_baud_gen_disabled;
        logic        clk;
        logic        rst_n;
        logic [15:0] i_div;
        logic        o_en;

        uart_16550_veryl_BaudGen u_dut (
            .i_clk  (clk  ),
            .i_rst_n(rst_n),
            .i_div  (i_div),
            .o_en   (o_en )
        );

        initial clk = 0;
        always #5 clk = ~clk;

        initial begin
            rst_n = 0;
            i_div = 0;

            repeat (5) @(posedge clk);
            rst_n = 1;

            for (int i = 0; i < 20; i++) begin
                @(posedge clk);
                if (o_en) $fatal(1, "o_en fired with div=0 at cycle %0d", i);
            end

            $finish();
        end
    endmodule
}}}
